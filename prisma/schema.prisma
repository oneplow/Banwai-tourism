// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  user_id       Int      @id @default(autoincrement())
  username      String   @db.VarChar(100)
  email         String   @unique @db.VarChar(150)
  password_hash String   @db.VarChar(255)
  role          UserRole @default(staff)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  staff_permissions StaffPermission[]
  comment_replies   CommentReply[]
  announcements     Announcement[]

  @@map("users")
}

model Category {
  category_id Int    @id @default(autoincrement())
  name        String @db.VarChar(100)
  icon        String @db.VarChar(100)
  pin_color   String? @db.VarChar(7)
  sort_order  Int    @default(0)

  places PlaceCategory[]

  @@map("categories")
}

model Place {
  place_id     Int      @id @default(autoincrement())
  name         String   @db.VarChar(200)
  description  String?  @db.Text
  history      String?  @db.Text
  latitude     Float
  longitude    Float
  map_url      String?  @db.Text
  address      String?  @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  open_hours   String?  @db.VarChar(100)
  cover_image  String?  @db.VarChar(255)
  view_count   Int      @default(0)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  categories        PlaceCategory[]
  images            PlaceImage[]
  staff_permissions StaffPermission[]
  comments          Comment[]
  favorites         Favorite[]
  view_stats        ViewStat[]

  @@map("places")
}

model PlaceCategory {
  id          Int      @id @default(autoincrement())
  place_id    Int
  category_id Int
  is_primary  Boolean  @default(false)

  place    Place    @relation(fields: [place_id], references: [place_id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [category_id])

  @@unique([place_id, category_id])
  @@map("place_categories")
}

model PlaceImage {
  image_id   Int    @id @default(autoincrement())
  place_id   Int
  image_url  String @db.VarChar(255)
  sort_order Int    @default(0)

  place Place @relation(fields: [place_id], references: [place_id])

  @@map("place_images")
}

model StaffPermission {
  id          Int      @id @default(autoincrement())
  user_id     Int
  place_id    Int
  assigned_at DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [user_id])
  place Place @relation(fields: [place_id], references: [place_id])

  @@unique([user_id, place_id])
  @@map("staff_permissions")
}

model Comment {
  comment_id Int           @id @default(autoincrement())
  place_id   Int
  guest_name String        @db.VarChar(100)
  rating     Int           @db.TinyInt
  comment    String?       @db.Text
  status     CommentStatus @default(pending)
  created_at DateTime      @default(now())

  place   Place          @relation(fields: [place_id], references: [place_id])
  replies CommentReply[]

  @@map("comments")
}

model CommentReply {
  reply_id   Int      @id @default(autoincrement())
  comment_id Int
  user_id    Int
  reply_text String   @db.Text
  created_at DateTime @default(now())

  comment Comment @relation(fields: [comment_id], references: [comment_id])
  user    User    @relation(fields: [user_id], references: [user_id])

  @@map("comment_replies")
}

model Announcement {
  announcement_id Int      @id @default(autoincrement())
  user_id         Int
  title           String   @db.VarChar(200)
  content         String   @db.Text
  image_url       String?  @db.VarChar(255)
  is_published    Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  user User @relation(fields: [user_id], references: [user_id])

  @@map("announcements")
}

model Favorite {
  favorite_id Int      @id @default(autoincrement())
  session_id  String   @db.VarChar(100)
  place_id    Int
  created_at  DateTime @default(now())

  place Place @relation(fields: [place_id], references: [place_id])

  @@unique([session_id, place_id])
  @@map("favorites")
}

model ViewStat {
  stat_id    Int      @id @default(autoincrement())
  place_id   Int
  view_date  DateTime @db.Date
  view_count Int      @default(0)

  place Place @relation(fields: [place_id], references: [place_id])

  @@unique([place_id, view_date])
  @@map("view_stats")
}

enum UserRole {
  admin
  staff
}

enum CommentStatus {
  pending
  approved
  hidden
}
